# Copy this file to local.properties and fill in your keys
# DO NOT commit local.properties to version control

# Android SDK path (set automatically by Android Studio)
sdk.dir=/path/to/Android/sdk

# Gemini API Key - get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Play Developer API Key
PLAY_API_KEY=your_play_api_key_here
